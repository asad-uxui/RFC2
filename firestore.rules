rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
       return request.resource.data;
    }

    function existing() {
       return resource.data;
    }

    function isValidIssueShape(data) {
       return data.keys().hasAll(['description', 'status', 'reporterId', 'createdAt', 'updatedAt'])
           && data.description is string && data.description.size() <= 2000
           && data.status in ['open', 'in-progress', 'resolved']
           && data.reporterId is string;
    }

    function isValidProjectShape(data) {
       return data.keys().hasAll(['name', 'createdAt', 'createdBy'])
           && data.name is string && data.name.size() <= 256;
    }

    // Issues collection
    match /issues/{issueId} {
       allow read: if true;
       allow create: if isValidId(issueId) && isValidIssueShape(incoming());
       allow update: if isValidIssueShape(incoming());
       allow delete: if true;
    }

    // Projects collection
    match /projects/{projectId} {
       allow read: if true;
       allow create: if isValidId(projectId) && isValidProjectShape(incoming());
       allow update: if true;
       allow delete: if true;
    }

    // Test connection doc
    match /test/{docId} {
       allow read: if true;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
